# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (Whisper transcription)
OPENAI_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# API key for webhook/voice endpoints (set to any random string)
DAILY_PLANNER_API_KEY=

# Google OAuth (Calendar integration)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: override redirect URI (otherwise derived from request origin)
GOOGLE_REDIRECT_URI=

# iCal feeds — secret "iCal format" URLs from Google Calendar settings
ATLAN_ICAL_URL=
PERSONAL_ICAL_URL=

# Granola meeting notes ingestion
GRANOLA_API_KEY=
# Comma-separated list of Jake's emails. Used to identify action items
# that are assigned to Jake (solo or co-owner) during extraction.
JAKE_EMAILS=jake.biskar@atlan.com,jake@justlandit.com,jakebiskar@gmail.com

# Public URL of the deployed app (used by n8n workflows to call back).
APP_URL=http://localhost:3000

# Cron job shared secret (optional; if set, cron routes require this header).
CRON_SECRET=
